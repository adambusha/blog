---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="flex flex-col items-center justify-center py-16 text-center corner-accent-double p-8">
    <h1 class="text-6xl md:text-8xl font-bold text-[var(--color-accent)] mb-4">
      404
    </h1>
    <h2 class="text-xl md:text-2xl font-semibold text-[var(--color-text)] mb-4">
      Page Not Found
    </h2>
    <p class="text-[var(--color-text-muted)] mb-8 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg hover:bg-[var(--color-accent-hover)] transition-colors"
    >
      &larr; Back to Home
    </a>
  </div>
</BaseLayout>
