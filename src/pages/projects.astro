---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Project One',
    description: 'A brief description of this project and what it does. This is placeholder content that should be replaced with actual project details.',
    url: 'https://github.com',
    tags: ['TypeScript', 'React'],
  },
  {
    title: 'Project Two',
    description: 'Another project description goes here. Replace this with real information about your actual projects.',
    url: 'https://github.com',
    tags: ['Python', 'FastAPI'],
  },
];
---

<BaseLayout title="Projects" description="A collection of projects I've worked on.">
  <Header slot="header" />
  <Footer slot="footer" />

  <h1 class="text-3xl md:text-4xl font-bold mb-8 text-[var(--color-text)]">
    Projects
  </h1>

  <p class="text-[var(--color-text-muted)] mb-8">
    A collection of projects I've built or contributed to.
  </p>

  <div class="grid gap-4">
    {projects.map((project) => (
      <ProjectCard
        title={project.title}
        description={project.description}
        url={project.url}
        tags={project.tags}
      />
    ))}
  </div>
</BaseLayout>
