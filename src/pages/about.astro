---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About" description="Learn more about me and this blog.">
  <Header slot="header" />
  <Footer slot="footer" />

  <h1 class="text-3xl md:text-4xl font-bold mb-8 text-[var(--color-text)]">
    About
  </h1>

  <div class="prose prose-lg max-w-none prose-p:text-[var(--color-text)] prose-headings:text-[var(--color-text)] prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline prose-strong:text-[var(--color-text)]">
    <p>
      Welcome to my corner of the internet. I'm a software developer who enjoys
      building things for the web and exploring new technologies.
    </p>

    <p>
      This blog is where I share my thoughts, learnings, and experiences in
      software development. Whether it's diving into a new framework, solving an
      interesting problem, or reflecting on the craft of programming, you'll
      find it here.
    </p>

    <p>
      Feel free to reach out if you'd like to connect or discuss anything you
      find on this site.
    </p>
  </div>
</BaseLayout>
