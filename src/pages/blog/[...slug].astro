---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const publishedPosts = allPosts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return publishedPosts.map((post, index) => {
    const nextPost = publishedPosts[index - 1];
    const prevPost = publishedPosts[index + 1];
    const toSummary = (p: typeof publishedPosts[number]) => ({
      slug: p.id,
      title: p.data.title,
      date: p.data.pubDate,
    });

    return {
      params: { slug: post.id },
      props: {
        post,
        nextPost: nextPost ? toSummary(nextPost) : undefined,
        prevPost: prevPost ? toSummary(prevPost) : undefined,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  nextPost?: { slug: string; title: string; date: Date };
  prevPost?: { slug: string; title: string; date: Date };
}

const { post, nextPost, prevPost } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  slug={post.id}
  nextPost={nextPost}
  prevPost={prevPost}
  headings={headings}
>
  <Content />
</PostLayout>
