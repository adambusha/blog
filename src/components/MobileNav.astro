---
import ThemeToggle from './ThemeToggle.astro';

export interface Props {
  navLinks: { href: string; label: string }[];
  currentPath: string;
}

const { navLinks, currentPath } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
}
---

<div class="mobile-nav-container">
  <!-- Hamburger button -->
  <button
    id="mobile-nav-trigger"
    type="button"
    class="p-2 -ml-2 text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
    aria-label="Open menu"
    aria-expanded="false"
  >
    <svg
      class="w-6 h-6"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>

  <!-- Overlay -->
  <div
    id="mobile-nav-overlay"
    class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity"
  >
  </div>

  <!-- Slide-out menu -->
  <div
    id="mobile-nav-menu"
    class="fixed top-0 left-0 bottom-0 w-64 bg-[var(--color-bg)] z-50 transform -translate-x-full transition-transform shadow-xl"
  >
    <div class="flex flex-col h-full">
      <!-- Close button -->
      <div class="flex items-center justify-between p-4 border-b border-[var(--color-border)]">
        <span class="text-sm font-medium text-[var(--color-text)]">Menu</span>
        <button
          id="mobile-nav-close"
          type="button"
          class="p-2 -mr-2 text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          aria-label="Close menu"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Navigation links -->
      <nav class="flex-1 p-4">
        <ul class="space-y-2">
          {
            navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                    isActive(href)
                      ? 'bg-accent/10 text-accent'
                      : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-secondary)]',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Theme toggle -->
      <div class="p-4 border-t border-[var(--color-border)]">
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--color-text-muted)]">Dark mode</span>
          <ThemeToggle />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initMobileNav() {
    const trigger = document.getElementById('mobile-nav-trigger');
    const overlay = document.getElementById('mobile-nav-overlay');
    const menu = document.getElementById('mobile-nav-menu');
    const closeBtn = document.getElementById('mobile-nav-close');

    if (!trigger || !overlay || !menu || !closeBtn) return;

    function openMenu() {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      menu.classList.remove('-translate-x-full');
      menu.classList.add('translate-x-0');
      trigger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      menu.classList.add('-translate-x-full');
      menu.classList.remove('translate-x-0');
      trigger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    trigger.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('-translate-x-full')) {
        closeMenu();
      }
    });
  }

  // Run on initial load - wait for DOM to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileNav);
  } else {
    initMobileNav();
  }

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initMobileNav);
</script>
