---
---

<button
  type="button"
  class="theme-toggle relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]"
  aria-label="Toggle dark mode"
>
  <span class="sr-only">Toggle dark mode</span>
  <span
    class="toggle-thumb inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition-transform"
  >
    <svg
      class="sun-icon h-4 w-4 text-amber-500"
      fill="currentColor"
      viewBox="0 0 20 20"
    >
      <path
        fill-rule="evenodd"
        d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
        clip-rule="evenodd"></path>
    </svg>
    <svg
      class="moon-icon h-4 w-4 text-slate-700 hidden"
      fill="currentColor"
      viewBox="0 0 20 20"
    >
      <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
    </svg>
  </span>
</button>

<script>
  function initThemeToggle() {
    const toggles = document.querySelectorAll('.theme-toggle');

    toggles.forEach((toggle) => {
      const thumb = toggle.querySelector('.toggle-thumb');
      const sunIcon = toggle.querySelector('.sun-icon');
      const moonIcon = toggle.querySelector('.moon-icon');

      if (!thumb || !sunIcon || !moonIcon) return;

      function updateToggle(isDark: boolean) {
        toggle.classList.toggle('bg-accent', isDark);
        toggle.classList.toggle('bg-gray-300', !isDark);
        thumb.classList.toggle('translate-x-5', isDark);
        thumb.classList.toggle('translate-x-1', !isDark);
        sunIcon.classList.toggle('hidden', isDark);
        moonIcon.classList.toggle('hidden', !isDark);
      }

      // Initialize based on current theme
      const isDark = document.documentElement.classList.contains('dark');
      updateToggle(isDark);

      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        // Update ALL toggles to stay in sync
        document.querySelectorAll('.theme-toggle').forEach((t) => {
          const th = t.querySelector('.toggle-thumb');
          const sun = t.querySelector('.sun-icon');
          const moon = t.querySelector('.moon-icon');
          if (th && sun && moon) {
            t.classList.toggle('bg-accent', isDark);
            t.classList.toggle('bg-gray-300', !isDark);
            th.classList.toggle('translate-x-5', isDark);
            th.classList.toggle('translate-x-1', !isDark);
            sun.classList.toggle('hidden', isDark);
            moon.classList.toggle('hidden', !isDark);
          }
        });
      });
    });
  }

  // Run on initial load - wait for DOM to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
