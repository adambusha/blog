---
import TagPill from './TagPill.astro';

export interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  slug: string;
}

const { title, date, description, tags = [], slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="py-4 border-b border-[var(--color-border)] last:border-b-0">
  <div class="flex flex-col gap-2">
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
      <h3 class="text-lg font-medium">
        <a
          href={`/blog/${slug}`}
          class="text-[var(--color-text)] hover:text-accent transition-colors"
        >
          {title}
        </a>
      </h3>
      <time
        datetime={date.toISOString()}
        class="text-sm text-[var(--color-text-muted)] shrink-0"
      >
        {formattedDate}
      </time>
    </div>

    {description && (
      <p class="text-sm text-[var(--color-text-muted)] line-clamp-2">
        {description}
      </p>
    )}

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-1">
        {tags.map((tag) => (
          <TagPill tag={tag} />
        ))}
      </div>
    )}
  </div>
</article>
