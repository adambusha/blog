---
import ThemeToggle from './ThemeToggle.astro';

export interface Props {
  /** Override the path crumb shown on the mobile top bar. Defaults to derived from URL. */
  mobilePath?: string;
}

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'index' },
  { href: '/blog', label: 'blog' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: 'about' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}

function derivePath(): string {
  if (pathname === '/') return 'index';
  const seg = pathname.replace(/^\/+/, '').split('/');
  return seg.filter(Boolean).join('/');
}

const { mobilePath } = Astro.props;
const crumb = mobilePath ?? derivePath();

const version = `v${new Date().getFullYear()}.${String(new Date().getMonth() + 1).padStart(2, '0')}`;
---

<header class="w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]">
  <!-- Desktop nav (md+) -->
  <nav class="hidden md:flex items-center justify-between px-12 py-5 font-mono text-[13px] overflow-x-auto">
    <div class="flex items-center gap-2.5">
      <span class="text-[var(--color-accent)] font-semibold">~/</span>
      <span class="text-[var(--color-text)] font-medium">adam.busha</span>
      <span class="text-[var(--color-dim)]">·</span>
      <span class="text-[var(--color-text-muted)]">{version}</span>
    </div>

    <ul class="flex gap-7 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'pb-1 no-underline transition-colors',
              isActive(href)
                ? 'text-[var(--color-text)] border-b border-[var(--color-accent)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3.5 text-[var(--color-text-muted)]">
      <button
        type="button"
        data-palette-open
        class="flex items-center gap-1.5 px-2.5 py-1 rounded border border-[var(--color-border)] bg-[var(--color-panel)] text-[11.5px] hover:text-[var(--color-text)] hover:border-[var(--color-accent)] transition-colors cursor-pointer"
        aria-label="Open command palette"
      >
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="5" cy="5" r="3.5" />
          <path d="M8 8l3 3" />
        </svg>
        ⌘K
      </button>
      <span
        aria-hidden="true"
        class="w-2 h-2 rounded-full bg-[var(--color-success)]"
        style="box-shadow: 0 0 6px var(--color-success)"
      ></span>
      <ThemeToggle />
    </div>
  </nav>

  <!-- Mobile top bar (< md) -->
  <div class="md:hidden flex items-center gap-2.5 px-4 pt-2 pb-3 font-mono text-[12.5px]">
    <span class="text-[var(--color-accent)] font-semibold">~/</span>
    <span class="text-[var(--color-text)] font-medium">adam.busha</span>
    <span class="text-[var(--color-dim)]">·</span>
    <span class="text-[var(--color-text-muted)] truncate">{crumb}</span>

    <div class="ml-auto flex items-center gap-2">
      <button
        type="button"
        class="theme-icon-toggle h-[30px] w-[30px] rounded-md border border-[var(--color-border)] bg-[var(--color-panel)] text-[var(--color-text-muted)] flex items-center justify-center p-0"
        aria-label="Toggle theme"
      >
        <!-- moon (shown in light mode = click to go dark) -->
        <svg class="moon-icon w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M12 8.4A5 5 0 116.6 2c0 .3-.1.6-.1.9a4.4 4.4 0 005.4 4.4l.1 1.1z" />
        </svg>
        <!-- sun (shown in dark mode = click to go light) -->
        <svg class="sun-icon w-3.5 h-3.5 hidden" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
          <circle cx="7" cy="7" r="2.6" />
          <path d="M7 1v1.4M7 11.6V13M1 7h1.4M11.6 7H13M2.6 2.6l1 1M10.4 10.4l1 1M2.6 11.4l1-1M10.4 3.6l1-1" />
        </svg>
      </button>
      <button
        type="button"
        data-palette-open
        class="h-[30px] px-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-panel)] text-[var(--color-text-muted)] flex items-center gap-1.5 font-mono text-[11.5px]"
        aria-label="Open command palette"
      >
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="5" cy="5" r="3.5" />
          <path d="M8 8l3 3" />
        </svg>
        ⌘K
      </button>
    </div>
  </div>
</header>

<script>
  function initThemeIcon() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-icon-toggle');
    const sync = () => {
      const isDark = document.documentElement.classList.contains('dark');
      buttons.forEach((b) => {
        const sun = b.querySelector('.sun-icon');
        const moon = b.querySelector('.moon-icon');
        sun?.classList.toggle('hidden', !isDark);
        moon?.classList.toggle('hidden', isDark);
      });
    };
    sync();
    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        // sync the slider toggle too
        document.querySelectorAll('.theme-toggle').forEach((t) => {
          const th = t.querySelector('.toggle-thumb');
          const s = t.querySelector('.sun-icon');
          const m = t.querySelector('.moon-icon');
          if (th && s && m) {
            t.classList.toggle('bg-accent', isDark);
            t.classList.toggle('bg-gray-300', !isDark);
            th.classList.toggle('translate-x-5', isDark);
            th.classList.toggle('translate-x-1', !isDark);
            s.classList.toggle('hidden', isDark);
            m.classList.toggle('hidden', !isDark);
          }
        });
        sync();
      });
    });
    // Also sync when the slider toggle is clicked
    document.querySelectorAll('.theme-toggle').forEach((t) =>
      t.addEventListener('click', () => requestAnimationFrame(sync))
    );
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeIcon);
  } else {
    initThemeIcon();
  }
  document.addEventListener('astro:after-swap', initThemeIcon);
</script>
