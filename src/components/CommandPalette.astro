---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

type Row =
  | { kind: 'nav'; id: string; label: string; hint: string; href: string }
  | { kind: 'post'; id: string; label: string; hint: string; href: string }
  | { kind: 'cmd'; id: string; label: string; hint: string; action: string };

const navRows: Row[] = [
  { kind: 'nav', id: 'home', label: 'go home', hint: 'cd ~', href: '/' },
  { kind: 'nav', id: 'blog', label: 'go blog', hint: 'cd blog/', href: '/blog' },
  { kind: 'nav', id: 'projects', label: 'go projects', hint: 'ls -t', href: '/projects' },
  { kind: 'nav', id: 'about', label: 'go about', hint: 'whoami', href: '/about' },
];

const postRows: Row[] = recentPosts.map((p) => ({
  kind: 'post',
  id: p.id,
  label: p.data.title,
  hint: p.data.pubDate.toISOString().slice(0, 10),
  href: `/blog/${p.id}`,
}));

const cmdRows: Row[] = [
  { kind: 'cmd', id: 'toggle-theme', label: 'toggle theme', hint: '⌘T', action: 'theme' },
  { kind: 'cmd', id: 'copy-rss', label: 'copy rss link', hint: '⌘R', action: 'rss' },
];

const all: Row[] = [...navRows, ...postRows, ...cmdRows];
---

<div
  id="cmd-palette"
  role="dialog"
  aria-modal="true"
  aria-label="Command palette"
  class="hidden fixed inset-0 z-50 palette-backdrop"
>
  <div
    id="cmd-palette-sheet"
    class="mx-auto mt-3 max-w-[640px] rounded-[14px] overflow-hidden bg-[var(--color-bg)] border border-[var(--color-border)] shadow-[0_24px_48px_rgba(0,0,0,0.3)] mx-3 md:mx-auto"
    style="animation: tmSlideDown 0.25s ease-out forwards;"
  >
    <!-- Search -->
    <div class="flex items-center gap-2.5 px-4 py-3.5 border-b border-[var(--color-border)] font-mono text-[14px]">
      <span class="text-[var(--color-accent)]">›</span>
      <input
        id="cmd-palette-input"
        type="text"
        autocomplete="off"
        placeholder="grep…"
        class="flex-1 bg-transparent border-0 outline-none text-[var(--color-text)] font-mono text-[14px] placeholder:text-[var(--color-text-muted)]"
      />
      <button
        type="button"
        data-palette-close
        class="bg-transparent border border-[var(--color-border)] rounded-[5px] px-2 py-0.5 font-mono text-[10.5px] text-[var(--color-text-muted)] cursor-pointer"
      >esc</button>
    </div>

    <!-- Sections -->
    <div id="cmd-palette-list" class="py-2 max-h-[60vh] overflow-y-auto">
      <div class="px-4 pt-2 pb-1 font-mono text-[10px] text-[var(--color-dim)] tracking-[0.5px]">NAVIGATE</div>
      {navRows.map((r) => (
        <button
          type="button"
          data-row
          data-kind={r.kind}
          data-href={'href' in r ? r.href : ''}
          class="palette-row w-full flex items-center gap-2.5 px-4 py-2.5 text-left bg-transparent border-0 border-l-2 border-transparent cursor-pointer"
        >
          <span class="palette-glyph font-mono text-[12px] text-[var(--color-text-muted)]">→</span>
          <span class="flex-1 text-[14px] text-[var(--color-text)]">{r.label}</span>
          <span class="font-mono text-[10.5px] text-[var(--color-dim)]">{r.hint}</span>
        </button>
      ))}

      {postRows.length > 0 && (
        <>
          <div class="px-4 pt-3 pb-1 font-mono text-[10px] text-[var(--color-dim)] tracking-[0.5px]">POSTS</div>
          {postRows.map((r) => (
            <button
              type="button"
              data-row
              data-kind={r.kind}
              data-href={'href' in r ? r.href : ''}
              class="palette-row w-full flex items-center gap-2.5 px-4 py-2.5 text-left bg-transparent border-0 border-l-2 border-transparent cursor-pointer"
            >
              <span class="palette-glyph font-mono text-[12px] text-[var(--color-text-muted)]">✎</span>
              <span class="flex-1 text-[14px] text-[var(--color-text)] truncate">{r.label}</span>
              <span class="font-mono text-[10.5px] text-[var(--color-dim)]">{r.hint}</span>
            </button>
          ))}
        </>
      )}

      <div class="px-4 pt-3 pb-1 font-mono text-[10px] text-[var(--color-dim)] tracking-[0.5px]">COMMANDS</div>
      {cmdRows.map((r) => (
        <button
          type="button"
          data-row
          data-kind={r.kind}
          data-action={'action' in r ? r.action : ''}
          class="palette-row w-full flex items-center gap-2.5 px-4 py-2.5 text-left bg-transparent border-0 border-l-2 border-transparent cursor-pointer"
        >
          <span class="palette-glyph font-mono text-[12px] text-[var(--color-text-muted)]">⌘</span>
          <span class="flex-1 text-[14px] text-[var(--color-text)]">{r.label}</span>
          <span class="font-mono text-[10.5px] text-[var(--color-dim)]">{r.hint}</span>
        </button>
      ))}

      <div id="cmd-palette-empty" class="hidden px-4 py-6 text-center font-mono text-[12px] text-[var(--color-text-muted)]">
        no matches
      </div>
    </div>

    <!-- Footer -->
    <div class="flex gap-3.5 px-4 py-2 border-t border-[var(--color-border)] bg-[var(--color-panel-alt)] font-mono text-[10.5px] text-[var(--color-dim)]">
      <span>↑↓ navigate</span>
      <span>↵ open</span>
      <span class="ml-auto" id="cmd-palette-count">{all.length} results</span>
    </div>
  </div>
</div>

<script>
  const ACCENT = 'var(--color-accent)';
  const ACCENT_BG = 'var(--color-accent-bg)';

  function initPalette() {
    const palette = document.getElementById('cmd-palette');
    const sheet = document.getElementById('cmd-palette-sheet');
    const input = document.getElementById('cmd-palette-input') as HTMLInputElement | null;
    const list = document.getElementById('cmd-palette-list');
    const empty = document.getElementById('cmd-palette-empty');
    const count = document.getElementById('cmd-palette-count');
    if (!palette || !input || !list) return;

    const rows = Array.from(list.querySelectorAll<HTMLButtonElement>('.palette-row'));
    let activeIdx = 0;
    let visibleRows: HTMLButtonElement[] = rows.slice();

    const setActive = (i: number) => {
      visibleRows.forEach((r) => {
        r.style.background = 'transparent';
        r.style.borderLeftColor = 'transparent';
        const g = r.querySelector<HTMLSpanElement>('.palette-glyph');
        if (g) g.style.color = 'var(--color-text-muted)';
      });
      if (visibleRows[i]) {
        const r = visibleRows[i];
        r.style.background = ACCENT_BG;
        r.style.borderLeftColor = `var(--color-accent)`;
        const g = r.querySelector<HTMLSpanElement>('.palette-glyph');
        if (g) g.style.color = ACCENT;
        r.scrollIntoView({ block: 'nearest' });
      }
      activeIdx = i;
    };

    const filter = (q: string) => {
      const query = q.trim().toLowerCase();
      visibleRows = [];
      rows.forEach((r) => {
        const text = (r.textContent || '').toLowerCase();
        const show = query === '' || text.includes(query);
        r.style.display = show ? 'flex' : 'none';
        if (show) visibleRows.push(r);
      });
      // hide section headers whose section has no visible rows
      const sections = list.querySelectorAll<HTMLDivElement>(':scope > div');
      // simpler: iterate child nodes, hide a heading if next sibling rows all hidden
      let nextHeader: HTMLElement | null = null;
      Array.from(list.children).forEach((child) => {
        const el = child as HTMLElement;
        if (el.classList?.contains('palette-row')) return;
        if (el.id === 'cmd-palette-empty') return;
        // it's a heading; check next siblings until another heading
        let hasVisible = false;
        let n: Element | null = el.nextElementSibling;
        while (n) {
          if (n.classList.contains('palette-row')) {
            if ((n as HTMLElement).style.display !== 'none') {
              hasVisible = true;
              break;
            }
          } else if ((n as HTMLElement).tagName === 'DIV' && (n as HTMLElement).id !== 'cmd-palette-empty') {
            break;
          }
          n = n.nextElementSibling;
        }
        el.style.display = hasVisible ? 'block' : 'none';
      });
      if (empty) empty.classList.toggle('hidden', visibleRows.length > 0);
      if (count) count.textContent = `${visibleRows.length} result${visibleRows.length === 1 ? '' : 's'}`;
      setActive(0);
    };

    const activateRow = (r: HTMLButtonElement) => {
      const kind = r.getAttribute('data-kind');
      const href = r.getAttribute('data-href');
      const action = r.getAttribute('data-action');
      if (kind === 'cmd' && action === 'theme') {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        closePalette();
        return;
      }
      if (kind === 'cmd' && action === 'rss') {
        try {
          const url = new URL('/rss.xml', window.location.origin).toString();
          navigator.clipboard?.writeText(url);
        } catch {}
        closePalette();
        return;
      }
      if (href) {
        window.location.href = href;
      }
    };

    const openPalette = () => {
      palette.classList.remove('hidden');
      palette.classList.add('flex');
      filter('');
      input.value = '';
      setTimeout(() => input.focus(), 30);
      document.body.style.overflow = 'hidden';
    };
    const closePalette = () => {
      palette.classList.add('hidden');
      palette.classList.remove('flex');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('[data-palette-open]').forEach((el) =>
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openPalette();
      })
    );
    document.querySelectorAll('[data-palette-close]').forEach((el) =>
      el.addEventListener('click', closePalette)
    );
    palette.addEventListener('click', (e) => {
      if (e.target === palette) closePalette();
    });
    sheet?.addEventListener('click', (e) => e.stopPropagation());

    input.addEventListener('input', () => filter(input.value));
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (palette.classList.contains('hidden')) openPalette();
        else closePalette();
        return;
      }
      if (palette.classList.contains('hidden')) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closePalette();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (visibleRows.length) setActive((activeIdx + 1) % visibleRows.length);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (visibleRows.length) setActive((activeIdx - 1 + visibleRows.length) % visibleRows.length);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (visibleRows[activeIdx]) activateRow(visibleRows[activeIdx]);
      }
    });

    rows.forEach((r) => {
      r.addEventListener('click', () => activateRow(r));
      r.addEventListener('mouseenter', () => {
        const i = visibleRows.indexOf(r);
        if (i >= 0) setActive(i);
      });
    });

    setActive(0);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPalette);
  } else {
    initPalette();
  }
  document.addEventListener('astro:after-swap', initPalette);
</script>
