---
import TagPill from './TagPill.astro';

export interface Props {
  title: string;
  description: string;
  url: string;
  tags?: string[];
}

const { title, description, url, tags = [] } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block p-5 rounded-lg border border-[var(--color-border)] hover:border-accent/50 bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg)] transition-all corner-accent corner-accent-hover"
>
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-medium text-[var(--color-text)] group-hover:text-accent transition-colors">
      {title}
    </h3>
    <svg
      class="w-4 h-4 shrink-0 text-[var(--color-text-muted)] group-hover:text-accent transition-colors"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
      ></path>
    </svg>
  </div>

  <p class="mt-2 text-sm text-[var(--color-text-muted)] line-clamp-2">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-3">
      {tags.map((tag) => (
        <TagPill tag={tag} linked={false} />
      ))}
    </div>
  )}
</a>
