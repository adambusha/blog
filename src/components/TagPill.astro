---
export interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = true } = Astro.props;
const href = `/tags/${tag.toLowerCase()}`;
---

{
  linked ? (
    <a
      href={href}
      class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent hover:bg-accent/20 transition-colors"
    >
      {tag}
    </a>
  ) : (
    <span class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent">
      {tag}
    </span>
  )
}
