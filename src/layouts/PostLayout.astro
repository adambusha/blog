---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { MarkdownHeading } from 'astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  image?: string;
  slug?: string;
  nextPost?: { slug: string; title: string; date: Date };
  prevPost?: { slug: string; title: string; date: Date };
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  pubDate,
  tags = [],
  image,
  slug = '',
  nextPost,
  prevPost,
  headings = [],
} = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const isoDate = pubDate.toISOString().slice(0, 10);
const filename = `${slug || 'post'}.md`;
---

<BaseLayout title={`${title} — Adam Busha`} description={description} image={image} hideMobileNav>
  <Footer slot="footer" />
  <!-- Mobile-specific article header (slim, with back + filename) -->
  <Fragment slot="header">
    <!-- Desktop header (md+) -->
    <div class="hidden md:contents">
      <Header />
    </div>

    <!-- Mobile reading top bar -->
    <header class="md:hidden bg-[var(--color-bg)]">
      <div class="flex items-center px-3.5 pt-2.5 pb-3 border-b border-[var(--color-border)] font-mono text-[12px] gap-2">
        <a
          href="/blog"
          class="h-[30px] px-2.5 rounded-md border border-[var(--color-border)] text-[var(--color-text-muted)] font-mono text-[11.5px] flex items-center gap-1.5 no-underline"
        >← blog</a>
        <div class="flex-1 text-center text-[var(--color-dim)] text-[11px] truncate">
          {filename}
        </div>
        <button
          type="button"
          class="theme-icon-toggle h-[30px] w-[30px] rounded-md border border-[var(--color-border)] text-[var(--color-text-muted)] flex items-center justify-center p-0"
          aria-label="Toggle theme"
        >
          <svg class="moon-icon w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M12 8.4A5 5 0 116.6 2c0 .3-.1.6-.1.9a4.4 4.4 0 005.4 4.4l.1 1.1z" />
          </svg>
          <svg class="sun-icon w-3.5 h-3.5 hidden" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
            <circle cx="7" cy="7" r="2.6" />
            <path d="M7 1v1.4M7 11.6V13M1 7h1.4M11.6 7H13M2.6 2.6l1 1M10.4 10.4l1 1M2.6 11.4l1-1M10.4 3.6l1-1" />
          </svg>
        </button>
      </div>
      <!-- Reading progress bar -->
      <div class="h-[2px] bg-[var(--color-border-soft)] relative">
        <div
          id="reading-progress"
          class="absolute left-0 top-0 h-full bg-[var(--color-accent)]"
          style="width: 0%"
        ></div>
      </div>
    </header>
  </Fragment>

  <!-- Single responsive article layout -->
  <div class="grid grid-cols-1 md:grid-cols-[220px_1fr_220px] md:min-h-[calc(100vh-65px)]">
    <!-- Left sidebar: TOC + Meta (desktop only) -->
    <aside class="hidden md:block pt-12 pl-12 pr-6 border-r border-[var(--color-border-soft)]">
      <div class="font-mono text-[11px] text-[var(--color-dim)] mb-3.5 tracking-wide uppercase">
        On This Page
      </div>
      {tocHeadings.length > 0 ? (
        <nav class="font-mono text-xs text-[var(--color-text-muted)] space-y-1.5" aria-label="Table of contents">
          {tocHeadings.map((h) => (
            <a
              href={`#${h.slug}`}
              data-toc-link
              data-toc-slug={h.slug}
              class="toc-link block no-underline transition-colors hover:text-[var(--color-text)]"
            >{h.text}</a>
          ))}
        </nav>
      ) : (
        <div class="font-mono text-xs text-[var(--color-dim)] italic">No sections</div>
      )}

      <div class="mt-8 pt-4 border-t border-[var(--color-border-soft)]">
        <div class="font-mono text-[11px] text-[var(--color-dim)] mb-2.5 tracking-wide uppercase">
          Meta
        </div>
        <div class="font-mono text-[11.5px] text-[var(--color-text-muted)] leading-[1.7]">
          <div>commit&nbsp; <span class="text-[var(--color-accent)]">a47f2b1</span></div>
          <div>posted&nbsp; <span class="text-[var(--color-text)]">{isoDate}</span></div>
        </div>
      </div>
    </aside>

    <!-- Main article column -->
    <article class="px-[22px] md:px-14 pt-6 md:pt-12 pb-9 md:pb-16 max-w-full md:max-w-[780px]">
      <!-- Mobile meta strip -->
      <div class="md:hidden flex gap-3 items-center flex-wrap font-mono text-[10.5px] text-[var(--color-dim)] mb-4 tracking-[0.3px]">
        <span>{isoDate}</span>
        <span>·</span>
        <span>5 min</span>
        <span>·</span>
        <span class="text-[var(--color-accent)]">commit a47f2b1</span>
      </div>

      <!-- Desktop breadcrumb -->
      <div class="hidden md:block font-mono text-xs text-[var(--color-text-muted)] mb-3.5">
        <a
          href="/blog"
          class="text-[var(--color-accent)] no-underline hover:underline"
        >blog</a><span class="text-[var(--color-accent)]">/</span>{slug || 'post'}.md
      </div>

      <h1 class="m-0 font-serif md:font-sans text-[32px] md:text-[42px] font-medium md:font-semibold tracking-[-0.5px] md:tracking-[-0.05rem] leading-[1.12] md:leading-[1.1] text-[var(--color-text)] text-balance">
        {title}
      </h1>

      {tags.length > 0 && (
        <div class="flex gap-1.5 md:gap-2 mt-3.5 md:mt-4 flex-wrap">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="inline-block px-2 py-0.5 font-mono text-[10.5px] md:text-[11px] text-[var(--color-text-muted)] border border-[var(--color-border)] rounded-sm no-underline md:hover:border-[var(--color-accent)] md:hover:text-[var(--color-text)] transition-colors"
            >{tag}</a>
          ))}
        </div>
      )}

      <div
        data-prose
        class="mt-6 md:mt-7 prose md:prose-lg max-w-none terminal-prose
          prose-headings:text-[var(--color-text)]
          prose-p:text-[var(--color-text-muted)]
          prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline
          prose-strong:text-[var(--color-text)]
          prose-code:text-[var(--color-code-text)] prose-code:bg-[var(--color-code-bg)]
          prose-pre:bg-[var(--color-code-bg)]
          prose-blockquote:border-l-[var(--color-accent)] prose-blockquote:text-[var(--color-text-muted)]
          prose-hr:border-[var(--color-border)]
          prose-li:text-[var(--color-text-muted)]
          prose-ul:text-[var(--color-text-muted)]
          prose-ol:text-[var(--color-text-muted)]"
      >
        <slot />
      </div>

      <!-- Mobile-only article footer: next card + share row -->
      <div class="md:hidden mt-9 pt-[22px] border-t border-[var(--color-border)]">
        {nextPost && (
          <>
            <div class="font-mono text-[10.5px] text-[var(--color-dim)] tracking-[0.4px] mb-2.5">NEXT →</div>
            <a
              href={`/blog/${nextPost.slug}`}
              class="block border border-[var(--color-border)] rounded-lg p-3.5 bg-[var(--color-panel)] no-underline"
            >
              <div class="font-mono text-[10.5px] text-[var(--color-dim)]">
                {nextPost.date.toISOString().slice(0, 10)}
              </div>
              <div class="text-[16px] font-semibold mt-1 tracking-[-0.2px] text-[var(--color-text)]">
                {nextPost.title}
              </div>
            </a>
          </>
        )}

        <div class="mt-[18px] grid grid-cols-3 gap-2 font-mono text-[11.5px] text-[var(--color-text-muted)]">
          <button
            type="button"
            data-copy-url
            class="px-1.5 py-2.5 rounded-md border border-[var(--color-border)] bg-transparent text-[var(--color-text-muted)] font-mono text-[11px] cursor-pointer"
          >$ copy url</button>
          <a
            href="/rss.xml"
            class="px-1.5 py-2.5 rounded-md border border-[var(--color-border)] bg-transparent text-[var(--color-text-muted)] font-mono text-[11px] text-center no-underline"
          >$ rss feed</a>
          <a
            href={`mailto:hi@adambusha.com?subject=${encodeURIComponent(`re: ${title}`)}`}
            class="px-1.5 py-2.5 rounded-md border border-[var(--color-border)] bg-transparent text-[var(--color-text-muted)] font-mono text-[11px] text-center no-underline"
          >$ reply email</a>
        </div>
      </div>
    </article>

    <!-- Right sidebar: Next + Previous + Share (desktop only) -->
    <aside class="hidden md:block pt-12 pl-4 pr-6">
      {nextPost && (
        <div class="mb-7">
          <div class="font-mono text-[11px] text-[var(--color-dim)] mb-3.5 tracking-wide uppercase">
            Next
          </div>
          <a href={`/blog/${nextPost.slug}`} class="no-underline group">
            <div class="text-[14px] font-medium text-[var(--color-text)] leading-snug group-hover:text-[var(--color-accent)] transition-colors">
              {nextPost.title}
            </div>
            <div class="mt-1.5 font-mono text-xs text-[var(--color-text-muted)]">
              {nextPost.date.toISOString().slice(0, 10)}
            </div>
          </a>
        </div>
      )}
      {prevPost && (
        <div class="mb-7">
          <div class="font-mono text-[11px] text-[var(--color-dim)] mb-3.5 tracking-wide uppercase">
            Previous
          </div>
          <a href={`/blog/${prevPost.slug}`} class="no-underline group">
            <div class="text-[14px] font-medium text-[var(--color-text)] leading-snug group-hover:text-[var(--color-accent)] transition-colors">
              {prevPost.title}
            </div>
            <div class="mt-1.5 font-mono text-xs text-[var(--color-text-muted)]">
              {prevPost.date.toISOString().slice(0, 10)}
            </div>
          </a>
        </div>
      )}
      <div class="pt-4 border-t border-[var(--color-border-soft)]">
        <div class="font-mono text-[11px] text-[var(--color-dim)] mb-2.5 tracking-wide uppercase">
          Share
        </div>
        <div class="flex flex-col gap-2 font-mono text-xs text-[var(--color-text-muted)] items-start">
          <button
            type="button"
            data-copy-url
            class="bg-transparent border-0 p-0 m-0 font-mono text-xs text-[var(--color-text-muted)] cursor-pointer hover:text-[var(--color-accent)] transition-colors text-left"
          >$ pbcopy &lt;&lt;&lt; url</button>
          <a
            href="/rss.xml"
            class="no-underline text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
          >$ open in rss</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    let ticking = false;
    const update = () => {
      const doc = document.documentElement;
      const scrollTop = window.scrollY || doc.scrollTop;
      const scrollHeight = doc.scrollHeight - doc.clientHeight;
      const pct = scrollHeight > 0 ? Math.min(1, Math.max(0, scrollTop / scrollHeight)) : 0;
      bar.style.width = `${(pct * 100).toFixed(1)}%`;
      ticking = false;
    };
    update();
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }

  function initTocScrollSpy() {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
    if (links.length === 0) return;

    const proseRoot = document.querySelector<HTMLElement>('[data-prose]');
    if (!proseRoot) return;

    const headings: HTMLElement[] = [];
    for (const link of links) {
      const slug = link.dataset.tocSlug;
      if (!slug) continue;
      const el = proseRoot.querySelector<HTMLElement>(`#${CSS.escape(slug)}`);
      if (el) headings.push(el);
    }
    if (headings.length === 0) return;

    const setActive = (slug: string | null) => {
      for (const link of links) {
        const isActive = link.dataset.tocSlug === slug;
        link.classList.toggle('text-[var(--color-accent)]', isActive);
      }
    };

    for (const link of links) {
      link.addEventListener('click', (e) => {
        const slug = link.dataset.tocSlug;
        if (!slug) return;
        const target = proseRoot.querySelector<HTMLElement>(`#${CSS.escape(slug)}`);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `#${slug}`);
      });
    }

    const update = () => {
      const offset = 120;
      let current: string | null = headings[0].id;
      for (const h of headings) {
        if (h.getBoundingClientRect().top - offset <= 0) {
          current = h.id;
        } else {
          break;
        }
      }
      setActive(current);
    };

    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
  }

  function initCopyUrl() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-url]').forEach((btn) => {
      btn.addEventListener('click', () => {
        try {
          navigator.clipboard?.writeText(window.location.href);
          const orig = btn.textContent;
          btn.textContent = '$ copied!';
          setTimeout(() => { btn.textContent = orig; }, 1200);
        } catch {}
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initReadingProgress();
      initCopyUrl();
      initTocScrollSpy();
    });
  } else {
    initReadingProgress();
    initCopyUrl();
    initTocScrollSpy();
  }
  document.addEventListener('astro:after-swap', () => {
    initReadingProgress();
    initCopyUrl();
    initTocScrollSpy();
  });
</script>
